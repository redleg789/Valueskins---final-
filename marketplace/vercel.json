{
  "crons": [
    {
      "path": "/api/cron/process-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/archive-deals",
      "schedule": "0 0 * * 0"
    }
  ],
  "env": {
    "DATABASE_URL": {
      "required": true
    },
    "CRON_SECRET": {
      "required": true
    }
  }
}
